<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SpamText" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryVariant">@color/brand_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_green</item>
        <item name="colorSecondaryVariant">@color/brand_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/brand_black</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
        <item name="android:statusBarColor">@color/brand_black</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.SpamText.Button.Outlined</item>
        <item name="materialButtonStyle">@style/Widget.SpamText.Button.Outlined</item>
    </style>

    <style name="Widget.SpamText.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_green</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">@color/brand_green</item>
    </style>
</resources>
